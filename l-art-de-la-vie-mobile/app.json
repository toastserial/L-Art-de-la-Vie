{
  "expo": {
    "name": "L'Art de la Vie POS",
    "slug": "l-art-de-la-vie-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/lartdela.png",
    "userInterfaceStyle": "light",
    "scheme": "lartdelavie",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lartdelavie.pos"
    },
    "android": {
      "package": "com.lartdelavie.pos",
      "adaptiveIcon": {
        "backgroundColor": "#00451F",
        "foregroundImage": "./assets/lartdela.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "L'Art de la Vie necesita acceso a tus fotos para agregar imágenes a los productos.",
          "cameraPermission": "L'Art de la Vie necesita usar la cámara para fotografiar productos.",
          "microphonePermission": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "d9be79cd-c2db-4110-a630-0f1db8427740"
      }
    },
    "owner": "cerialqiller321"
  }
}
